# Global configuration section
#   Values here are used as defaults for any following Channel section that
#   doesn't specify them.
Expunge Both
Create Both
Sync Full
SyncState *

# More sections follow
#
# !!!! Note that empty lines delimit sections !!!!


# Fetch password from gnome-keyring:
#PassCmd "gnome-keyring-query get mail_pw"
# Fetch password from .netrc:
#PassCmd "sed -n -e 's,^machine work\\.host\\.com login tehuser password \\(.*\\),\\1,p' < $HOME/.netrc"
# Fetch password from a gpg-encrypted file:
#PassCmd "gpg --quiet --for-your-eyes-only --decrypt $HOME/imappassword.gpg"
# Fetch password from pwmd (http://pwmd.sourceforge.net/):
#PassCmd "echo -ne 'GET myIsp\\tpassword' | pwmc datafile"

MaildirStore personal-local
Path ~/.mail/personal/
Inbox ~/.mail/personal/Inbox
SubFolders Verbatim

IMAPStore personal-remote
Host imap.gmail.com
UserCmd "cat ~/.mail/personal-username"
PassCmd "pass $(cat ~/.mail/personal-username)"
TLSType IMAPS
Timeout 120

Channel personal-inbox
Far :personal-remote:INBOX
Near :personal-local:Inbox

Channel personal-sent
Far :personal-remote:"[Gmail]/Sent Mail"
Near :personal-local:Sent

Channel personal-archive
Far :personal-remote:"[Gmail]/All Mail"
Near :personal-local:Archive

Channel personal-spam
Far :personal-remote:"[Gmail]/Spam"
Near :personal-local:Spam

Channel personal-trash
Far :personal-remote:"[Gmail]/Trash"
Near :personal-local:Trash

Channel personal-drafts
Far :personal-remote:"[Gmail]/Drafts"
Near :personal-local:Drafts

Group personal
Channel personal-inbox
Channel personal-sent
Channel personal-archive
Channel personal-spam
Channel personal-trash
Channel personal-drafts

